{
  "name": "recreation-planner",
  "version": "1.4.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "bump": "changeset version",
    "clean:localstorage": "rm -f vite-storage*",
    "dev": "next dev --turbopack",
    "lint": "eslint .",
    "prepare": "husky",
    "start": "next start",
    "test": "bash -c 'vitest run ${@:2}; code=$?; pnpm clean:localstorage; exit \"$code\"' bash",
    "test:dev": "sh -c 'vitest; code=$?; pnpm clean:localstorage; exit \"$code\"'"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "@vercel/speed-insights": "^2.0.0",
    "daisyui": "^5.5.19",
    "date-fns": "^4.1.0",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@ionic/prettier-config": "^4.0.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.8.0",
    "@types/react": "npm:types-react@19.0.0-rc.1",
    "@types/react-dom": "npm:types-react-dom@19.0.0-rc.1",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.5",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "prettier": "@ionic/prettier-config",
  "lint-staged": {
    "*.{js,jsx,ts,tsx,css,md,json}": [
      "prettier --write",
      "eslint"
    ]
  },
  "pnpm": {
    "overrides": {
      "@types/react": "npm:types-react@19.0.0-rc.1",
      "@types/react-dom": "npm:types-react-dom@19.0.0-rc.1"
    }
  },
  "packageManager": "pnpm@11.1.2"
}
